<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>The Midnight Cake Mystery - Cinematic Edition</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Special+Elite&family=Courier+Prime:ital,wght=0,400;0,705;1,400&family=Plus+Jakarta+Sans:wght=300;400;600;800&display=swap" rel="stylesheet">
  
  <style>
    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      background-color: #030712; /* Deepest Blue/Black */
      color: #f1f5f9;
      overflow-x: hidden;
    }
    .font-dossier { font-family: 'Courier Prime', monospace; }
    .font-detective { font-family: 'Special Elite', system-ui; }
    
    /* ==========================================
       CINEMATIC LIGHTING & EFFECTS
       ========================================== */
    .noir-bg {
      background: radial-gradient(circle at 50% 30%, #1e1b4b 0%, #030712 70%);
    }
    .vignette {
      box-shadow: inset 0 0 120px rgba(0, 0, 0, 0.95);
      pointer-events: none;
    }
    
    @keyframes sweepLight {
      0%, 100% { transform: translateX(-50%) translateY(-50%) rotate(-15deg); opacity: 0.15; }
      50% { transform: translateX(-40%) translateY(-45%) rotate(15deg); opacity: 0.25; }
    }
    .ambient-flashlight {
      position: absolute;
      top: 30%; left: 50%;
      width: 800px; height: 800px;
      background: radial-gradient(circle, rgba(252,211,77,0.15) 0%, rgba(0,0,0,0) 60%);
      border-radius: 50%;
      animation: sweepLight 12s infinite ease-in-out;
      pointer-events: none;
      z-index: 0;
    }

    @keyframes flicker {
      0%, 19%, 21%, 23%, 25%, 54%, 56%, 100% { opacity: 1; filter: drop-shadow(0 0 8px rgba(251, 191, 36, 0.8)); }
      20%, 24%, 55% { opacity: 0.5; filter: none; }
    }
    .neon-text { animation: flicker 7s infinite alternate; color: #fbbf24; }

    /* Particles */
    @keyframes floatUp {
      0% { transform: translateY(100vh) scale(0); opacity: 0; }
      50% { opacity: 0.6; }
      100% { transform: translateY(-100px) scale(1.5); opacity: 0; }
    }
    .dust-particle {
      position: absolute;
      background: #fde68a;
      border-radius: 50%;
      animation: floatUp linear infinite;
      pointer-events: none;
      z-index: 1;
    }

    /* Transitions */
    .scene-enter { animation: fadeInScale 0.6s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
    @keyframes fadeInScale {
      from { opacity: 0; transform: scale(0.95) translateY(20px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }

    /* ==========================================
       DETECTIVE EMMA SVG ANIMATIONS
       ========================================== */
    .emma-container { position: relative; z-index: 10; display: flex; justify-content: center; align-items: center; }
    
    /* Idle Breathing */
    @keyframes breath { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
    .anim-body { animation: breath 3s infinite ease-in-out; }

    /* Walking (Intro) */
    @keyframes walkBounce { 0%, 100% { transform: translateY(0) rotate(0); } 25% { transform: translateY(-8px) rotate(2deg); } 50% { transform: translateY(0) rotate(0); } 75% { transform: translateY(-8px) rotate(-2deg); } }
    .anim-walk { animation: walkBounce 1.2s infinite linear; }

    /* Flashlight Scan (Suspense) */
    @keyframes scanLight { 0%, 100% { transform: rotate(-30deg); } 50% { transform: rotate(30deg); } }
    .anim-scan { animation: scanLight 4s infinite ease-in-out; transform-origin: 150px 200px; }

    /* Investigating (Kneeling/Glass) */
    @keyframes hoverGlass { 0%, 100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-10px, 15px) scale(1.1); } }
    .anim-glass { animation: hoverGlass 3s infinite ease-in-out; transform-origin: 150px 150px; }

    /* Writing Notes */
    @keyframes writeNotes { 0%, 100% { transform: rotate(0deg) translateX(0); } 50% { transform: rotate(-5deg) translateX(-5px); } }
    .anim-write { animation: writeNotes 0.5s infinite ease-in-out; transform-origin: 200px 220px; }

    /* Thumbs Up (Correct) */
    @keyframes thumbsUp { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-10px) scale(1.1); } }
    .anim-success { animation: thumbsUp 1s infinite ease-in-out; transform-origin: 200px 200px; }

    /* Confused (Wrong) */
    @keyframes scratch { 0%, 100% { transform: rotate(0deg); } 50% { transform: rotate(-25deg); } }
    .anim-confused { animation: scratch 1s infinite ease-in-out; transform-origin: 120px 180px; }

    /* Pointing (Game Over) */
    @keyframes pointAccuse { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(8px); } }
    .anim-point { animation: pointAccuse 1.5s infinite ease-in-out; transform-origin: 150px 220px; }

    /* Audio Bar */
    @keyframes wavePulse { 0%, 100% { height: 6px; } 50% { height: 22px; } }
    .audio-bar { animation: wavePulse 1.2s infinite ease-in-out; }
    .bar-1 { animation-delay: 0.1s; } .bar-2 { animation-delay: 0.3s; }
    .bar-3 { animation-delay: 0.5s; } .bar-4 { animation-delay: 0.2s; }
  </style>
</head>
<body class="noir-bg min-h-screen relative">
  
  <div class="ambient-flashlight"></div>
  <div class="vignette absolute inset-0 z-50"></div>
  <div id="particles" class="absolute inset-0 z-0 overflow-hidden"></div>

  <div id="root" class="relative z-20 container mx-auto max-w-3xl min-h-screen flex items-center justify-center p-4"></div>

  <script type="text/babel">
    const { useState, useEffect, useRef } = React;
    const ReactDOM = window.ReactDOM;

    // --- UTILS: Particles ---
    function initParticles() {
      const container = document.getElementById('particles');
      container.innerHTML = '';
      for(let i=0; i<20; i++) {
        const p = document.createElement('div');
        p.className = 'dust-particle';
        p.style.width = Math.random() * 4 + 2 + 'px';
        p.style.height = p.style.width;
        p.style.left = Math.random() * 100 + '%';
        p.style.animationDuration = Math.random() * 10 + 10 + 's';
        p.style.animationDelay = Math.random() * -10 + 's';
        container.appendChild(p);
      }
    }

    // --- ICONS ---
    const Icon = ({ name, size=24, className="" }) => {
      const icons = {
        play: <path d="M5 3l14 9-14 9V3z" />,
        book: <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>,
        settings: <><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></>,
        musicOn: <><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></>,
        musicOff: <><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/><line x1="1" y1="1" x2="23" y2="23"/></>,
        soundOn: <><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></>,
        soundOff: <><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></>,
        shieldCheck: <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></>,
        shieldX: <><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/></>,
        message: <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>,
        lightbulb: <><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A5.5 5.5 0 0 0 7 8c0 1.3.5 2.6 1.5 3.5.8.8 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/></>,
        arrowRight: <><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></>,
        userPlus: <><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></>,
        search: <><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></>,
        volume2: <><path d="M11 5 6 9H2v6h4l5 4V5z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></>,
        volumeX: <><path d="M11 5 6 9H2v6h4l5 4V5z"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/></>
      };
      return (
        <svg xmlns="http://www.w3.org/2000/svg" width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round" className={className}>
          {icons[name]}
        </svg>
      );
    };

    // --- AUDIO ENGINE (100% Offline Web Audio API) ---
    class AudioEngine {
      constructor() {
        this.ctx = null;
        this.bgmNodes = [];
        this.bgmGain = null;
        this.sfxEnabled = true;
        this.bgmEnabled = true;
        this.initialized = false;
      }
      
      init() {
        if (!this.ctx) {
          const AudioContext = window.AudioContext || window.webkitAudioContext;
          this.ctx = new AudioContext();
          this.initialized = true;
        }
        if (this.ctx.state === 'suspended') this.ctx.resume();
      }

      playSFX(type) {
        if (!this.sfxEnabled || !this.initialized) return;
        const t = this.ctx.currentTime;
        const osc = this.ctx.createOscillator();
        const gain = this.ctx.createGain();
        osc.connect(gain);
        gain.connect(this.ctx.destination);

        switch(type) {
          case 'click':
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(600, t);
            osc.frequency.exponentialRampToValueAtTime(100, t + 0.1);
            gain.gain.setValueAtTime(0.1, t);
            gain.gain.exponentialRampToValueAtTime(0.001, t + 0.1);
            osc.start(t); osc.stop(t + 0.1);
            break;
          case 'typewriter':
            const bufferSize = this.ctx.sampleRate * 0.05; 
            const buffer = this.ctx.createBuffer(1, bufferSize, this.ctx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) { data[i] = Math.random() * 2 - 1; }
            const noise = this.ctx.createBufferSource();
            noise.buffer = buffer;
            const filter = this.ctx.createBiquadFilter();
            filter.type = 'highpass';
            filter.frequency.value = 2000;
            const noiseGain = this.ctx.createGain();
            noiseGain.gain.setValueAtTime(0.05, t);
            noiseGain.gain.exponentialRampToValueAtTime(0.001, t + 0.05);
            noise.connect(filter); filter.connect(noiseGain); noiseGain.connect(this.ctx.destination);
            noise.start(t);
            break;
          case 'correct':
            const freqs = [523.25, 659.25, 783.99, 1046.50]; 
            freqs.forEach((f, i) => {
              const o = this.ctx.createOscillator();
              const g = this.ctx.createGain();
              o.type = 'sine';
              o.frequency.value = f;
              g.gain.setValueAtTime(0, t + i*0.08);
              g.gain.linearRampToValueAtTime(0.1, t + i*0.08 + 0.02);
              g.gain.exponentialRampToValueAtTime(0.001, t + i*0.08 + 0.5);
              o.connect(g); g.connect(this.ctx.destination);
              o.start(t + i*0.08); o.stop(t + i*0.08 + 0.5);
            });
            break;
          case 'wrong':
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(150, t);
            osc.frequency.linearRampToValueAtTime(80, t + 0.4);
            gain.gain.setValueAtTime(0.15, t);
            gain.gain.exponentialRampToValueAtTime(0.001, t + 0.4);
            const osc2 = this.ctx.createOscillator();
            osc2.type = 'square';
            osc2.frequency.setValueAtTime(145, t);
            osc2.frequency.linearRampToValueAtTime(75, t + 0.4);
            osc2.connect(gain);
            osc.start(t); osc2.start(t);
            osc.stop(t + 0.4); osc2.stop(t + 0.4);
            break;
          case 'transition':
            osc.type = 'sine';
            osc.frequency.setValueAtTime(50, t);
            osc.frequency.exponentialRampToValueAtTime(300, t + 0.3);
            gain.gain.setValueAtTime(0, t);
            gain.gain.linearRampToValueAtTime(0.1, t + 0.15);
            gain.gain.linearRampToValueAtTime(0, t + 0.3);
            osc.start(t); osc.stop(t + 0.3);
            break;
        }
      }

      startBGM() {
        if (!this.initialized) this.init();
        if (!this.bgmEnabled || this.bgmNodes.length > 0) return;
        
        this.bgmGain = this.ctx.createGain();
        this.bgmGain.gain.setValueAtTime(0.05, this.ctx.currentTime);
        this.bgmGain.connect(this.ctx.destination);

        const createDrone = (freq, type) => {
          const osc = this.ctx.createOscillator();
          osc.type = type;
          osc.frequency.value = freq;
          osc.connect(this.bgmGain);
          osc.start();
          this.bgmNodes.push(osc);
        };

        createDrone(55, 'sine');
        createDrone(56.5, 'sine');
        createDrone(110, 'triangle');
      }

      stopBGM() {
        if (this.bgmGain) {
          this.bgmGain.gain.linearRampToValueAtTime(0, this.ctx.currentTime + 1);
          setTimeout(() => {
            this.bgmNodes.forEach(n => n.stop());
            this.bgmNodes = [];
          }, 1000);
        }
      }

      toggleSFX() { this.sfxEnabled = !this.sfxEnabled; }
      toggleBGM() { 
        this.bgmEnabled = !this.bgmEnabled; 
        if(this.bgmEnabled) this.startBGM(); else this.stopBGM();
      }
    }
    const audio = new AudioEngine();

    // --- TYPEWRITER COMPONENT ---
    const Typewriter = ({ text, onComplete, speed = 25 }) => {
      const [displayed, setDisplayed] = useState('');
      
      useEffect(() => {
        setDisplayed('');
        let i = 0;
        let lastSoundTime = 0;
        const interval = setInterval(() => {
          setDisplayed(text.substring(0, i + 1));
          if (Date.now() - lastSoundTime > 60 && text[i] !== ' ') {
            audio.playSFX('typewriter');
            lastSoundTime = Date.now();
          }
          i++;
          if (i >= text.length) {
            clearInterval(interval);
            if (onComplete) onComplete();
          }
        }, speed);
        return () => clearInterval(interval);
      }, [text, speed]);

      return <span className="whitespace-pre-line">{displayed}</span>;
    };

    // --- ANIMATED DETECTIVE SVG ---
    const AnimatedDetective = ({ state, speaking }) => {
      let containerClass = "anim-body";
      let armContent = null;
      let eyesContent = null;
      let mouthContent = null;

      if (state === 'start') {
        containerClass = "anim-walk";
        armContent = (
          <g className="anim-scan">
            <path d="M210 240 L280 220 L280 260 Z" fill="#fbbf24" opacity="0.4" />
            <rect x="200" y="235" width="25" height="10" rx="3" fill="#1e1b4b" />
            <circle cx="195" cy="240" r="10" fill="#fde68a" />
          </g>
        );
        eyesContent = <g fill="#1e1b4b"><circle cx="138" cy="162" r="5"/><circle cx="182" cy="162" r="5"/></g>;
        mouthContent = <path d="M150 188 L170 188" stroke="#1e1b4b" strokeWidth="4" fill="none" strokeLinecap="round" />;
      } else if (state === 'playing') {
        containerClass = "anim-body";
        armContent = (
          <g className="anim-glass">
            <line x1="110" y1="230" x2="80" y2="255" stroke="#1e1b4b" strokeWidth="6" strokeLinecap="round" />
            <circle cx="70" cy="265" r="18" stroke="#fbbf24" strokeWidth="4" fill="rgba(255,255,255,0.2)" />
            <circle cx="110" cy="230" r="8" fill="#fde68a" />
          </g>
        );
        eyesContent = <g fill="#1e1b4b"><circle cx="138" cy="162" r="5"/><circle cx="182" cy="162" r="5"/></g>;
        mouthContent = <path d="M150 188 Q160 190 170 188" stroke="#1e1b4b" strokeWidth="3" fill="none" strokeLinecap="round" />;
      } else if (state === 'interrogate') {
        containerClass = "anim-body";
        armContent = (
          <g className="anim-write">
            <rect x="180" y="210" width="30" height="40" rx="2" fill="#f8fafc" stroke="#1e1b4b" strokeWidth="2" transform="rotate(15 180 210)"/>
            <line x1="205" y1="215" x2="190" y2="245" stroke="#1e1b4b" strokeWidth="3" strokeLinecap="round" />
            <circle cx="215" cy="230" r="8" fill="#fde68a" />
          </g>
        );
        eyesContent = <g fill="#1e1b4b"><circle cx="138" cy="162" r="5"/><circle cx="182" cy="162" r="5"/></g>;
        mouthContent = <path d="M155 188 L165 188" stroke="#1e1b4b" strokeWidth="4" fill="none" strokeLinecap="round" />;
      } else if (state === 'correct') {
        armContent = (
          <g className="anim-success">
            <path d="M195 215 Q220 190 230 205 Q235 215 220 235" fill="#fde68a" stroke="#1e1b4b" strokeWidth="3" />
            <circle cx="232" cy="196" r="6" fill="#fde68a" stroke="#1e1b4b" strokeWidth="2" />
          </g>
        );
        eyesContent = <g stroke="#1e1b4b" strokeWidth="4" fill="none" strokeLinecap="round"><path d="M130 164 Q138 158 146 164"/><path d="M174 162 Q182 170 190 162"/></g>;
        mouthContent = <path d="M148 184 Q160 198 172 184" stroke="#1e1b4b" strokeWidth="4" fill="none" strokeLinecap="round" />;
      } else if (state === 'wrong') {
        armContent = (
          <g className="anim-confused">
            <path d="M105 185 Q75 140 100 120" fill="none" stroke="#fde68a" strokeWidth="12" strokeLinecap="round" />
            <text x="50" y="110" fill="#fbbf24" fontSize="28" fontWeight="bold" className="font-detective animate-bounce">?</text>
          </g>
        );
        eyesContent = <g stroke="#1e1b4b" strokeWidth="3" fill="none" strokeLinecap="round"><path d="M130 158 L142 166 M142 158 L130 166"/><path d="M174 158 L186 166 M186 158 L174 166"/></g>;
        mouthContent = <path d="M152 190 Q160 182 168 190" stroke="#1e1b4b" strokeWidth="3" fill="none" strokeLinecap="round" />;
      } else if (state === 'gameover') {
        armContent = (
          <g className="anim-point">
            <line x1="200" y1="230" x2="270" y2="210" stroke="#fde68a" strokeWidth="12" strokeLinecap="round" />
            <line x1="200" y1="230" x2="270" y2="210" stroke="#1e1b4b" strokeWidth="2" strokeLinecap="round" />
            <circle cx="200" cy="230" r="10" fill="#fde68a" />
          </g>
        );
        eyesContent = <g fill="#1e1b4b"><circle cx="138" cy="162" r="5"/><circle cx="182" cy="162" r="5"/></g>;
        mouthContent = <ellipse cx="160" cy="188" rx="8" ry="12" fill="#1e1b4b" />;
      }

      if (speaking) {
         mouthContent = <ellipse cx="160" cy="188" rx="6" ry="10" fill="#1e1b4b" className="animate-pulse" />;
      }

      return (
        <div className="emma-container py-2">
          <svg viewBox="0 0 320 320" className="w-48 h-48 drop-shadow-xl">
            <g className={containerClass}>
              <path d="M100 130 C90 150 90 220 120 220 C130 220 140 180 140 160" fill="#9d174d" />
              <path d="M220 130 C230 150 230 220 200 220 C190 220 180 180 180 160" fill="#9d174d" />
              <rect x="110" y="130" width="100" height="70" rx="35" fill="#fde68a" />
              <g stroke="#1e1b4b" strokeWidth="5" fill="none">
                <circle cx="138" cy="162" r="16" fill="rgba(251,191,36,0.1)" />
                <circle cx="182" cy="162" r="16" fill="rgba(251,191,36,0.1)" />
                <line x1="154" y1="162" x2="166" y2="162" />
              </g>
              {eyesContent}
              {mouthContent}
              <path d="M106 135 Q160 90 214 135" fill="#e11d48" />
              <path d="M90 125 Q160 115 230 125" stroke="#1e1b4b" strokeWidth="8" strokeLinecap="round" />
              <path d="M110 122 L116 85 C118 72, 202 72, 204 85 L210 122 Z" fill="#334155" stroke="#1e1b4b" strokeWidth="3" />
              <rect x="115" y="106" width="90" height="12" fill="#1e1b4b" />
              <path d="M112 215 L208 215 L230 300 L90 300 Z" fill="#64748b" stroke="#1e1b4b" strokeWidth="4" />
              <path d="M112 215 L160 270 L160 300 L90 300 Z" fill="#475569" stroke="#1e1b4b" strokeWidth="3" />
              <path d="M208 215 L160 270 L160 300 L230 300 Z" fill="#334155" stroke="#1e1b4b" strokeWidth="3" />
              <path d="M125 215 C135 230, 185 230, 195 215" stroke="#9f1239" strokeWidth="12" fill="none" strokeLinecap="round" />
              {armContent}
            </g>
          </svg>
        </div>
      );
    };

    // --- GAME DATA (BALANCED: 5 Past Continuous vs 5 Simple Past) ---
    const PREDEFINED_QUESTIONS = [
      {
        id: 1,
        type: 'multiple-choice',
        storyContext: "Detective Emma arrives at the messy staff room. Crumbs are everywhere! She questions Mr. Brown first.",
        questionText: "Mr. Brown: \"I ________ a cup of tea when I heard a loud crash in the hallway.\"",
        options: ["drank", "was drinking", "am drinking"],
        correctAnswer: "was drinking",
        explanation: "Rule (Past Continuous): Used for a long background action that was already in progress before the short disruption.",
        hint: "Look at the background activity. What was Mr. Brown doing before the crash interrupted him?",
        interrogation: "I swear on my history books! I was just enjoying my Earl Grey tea!",
        storyContinuation: "Mr. Brown seems honest, but the loud crash needs further investigation."
      },
      {
        id: 2,
        type: 'fill-in-the-blank',
        storyContext: "Mr. Brown explains what happened immediately after hearing the noise.",
        questionText: "Mr. Brown: \"While I was running out of the staff room to check the noise, I ________ (bump) into Alex.\"",
        correctAnswer: "bumped",
        explanation: "Rule (Simple Past): Used for a quick, sudden action that breaks into or interrupts a continuous action in progress.",
        hint: "The running was already happening. What sudden event happened right in the middle of it?",
        interrogation: "I ran out as fast as my old legs could carry me, and boom! Alex was standing right there.",
        storyContinuation: "Emma marks down Alex's name in her notes. Time to talk to the student."
      },
      {
        id: 3,
        type: 'multiple-choice',
        storyContext: "Alex enters wearing a heavy backpack, frantically wiping crumbs from his mouth.",
        questionText: "Alex: \"I ________ into the gym when Mr. Brown suddenly spilled his tea on me!\"",
        options: ["walked", "was walked", "was walking"],
        correctAnswer: "was walking",
        explanation: "Rule (Past Continuous): Alex's movement towards the gym was a continuous action over a period of time.",
        hint: "The spill was a quick surprise. What was Alex continuously doing before that happened?",
        interrogation: "Look at my shirt! It's ruined! I was minding my own business walking down the hall.",
        storyContinuation: "Alex points to a big wet stain on his clothes as proof of his path."
      },
      {
        id: 4,
        type: 'fill-in-the-blank',
        storyContext: "Emma squints suspiciously at Alex's heavy backpack and demands to know more.",
        questionText: "Alex: \"Well... while the party DJ was playing my favorite song, I suddenly ________ (realize) I lost my phone.\"",
        correctAnswer: "realized",
        explanation: "Rule (Simple Past): Realizing something is a sudden, instant mental event that interrupts a background action.",
        hint: "The music was blasting continuously. What sudden moment of realization hit him?",
        interrogation: "My backpack? It's just heavy gym equipment! I was looking for my phone!",
        storyContinuation: "Emma doesn't buy Alex's story entirely. She decides to check the hallway CCTV logs."
      },
      {
        id: 5,
        type: 'multiple-choice',
        storyContext: "On the security feed, Emma spots Mia, the star student, sneaking near the kitchen cabinet.",
        questionText: "While Mia was looking around the dark kitchen, she accidentally ________ a large tray of frosting.",
        options: ["dropped", "was dropping", "drops"],
        correctAnswer: "dropped",
        explanation: "Rule (Simple Past): Dropping an item is a sudden, momentary action that interrupts the continuous action of looking around.",
        hint: "Did the dropping of the tray happen slowly over time, or was it a quick, sudden accident?",
        interrogation: "I panicked! The shadows on the wall startled me!",
        storyContinuation: "Frosting splattered everywhere on the camera screen. Emma brings Mia in for a chat."
      },
      {
        id: 6,
        type: 'fill-in-the-blank',
        storyContext: "Mia is sobbing softly in the room, holding a pink-stained paper napkin.",
        questionText: "Mia: \"I ________ (hide) behind the metal lockers when the principal walked past.\"",
        correctAnswer: "was hiding",
        explanation: "Rule (Past Continuous): Hiding was the ongoing background situation that was happening when the principal passed by.",
        hint: "Mia was already in that position before the principal made his appearance.",
        interrogation: "I was just trying to avoid my strict math teacher, please believe me!",
        storyContinuation: "Mia seems genuinely terrified, but she points out that someone else left foot tracks."
      },
      {
        id: 7,
        type: 'multiple-choice',
        storyContext: "Emma continues checking the timeline. She interviews the school Principal about his walk.",
        questionText: "Principal: \"While I ________ down the corridor, I discovered trails of chocolate crumbs.\"",
        options: ["was walking", "walked", "walks"],
        correctAnswer: "was walking",
        explanation: "Rule (Past Continuous): Use Past Continuous after 'while' to emphasize an action that was ongoing over a duration.",
        hint: "The walking was a continuous process during which he made the sudden discovery.",
        interrogation: "I was doing my standard night patrol of the school grounds when I saw the tracks!",
        storyContinuation: "The trail of sweet crumbs leads straight down into the school basement."
      },
      {
        id: 8,
        type: 'fill-in-the-blank',
        storyContext: "Emma descends into the quiet basement and pushes open the heavy janitor's closet door.",
        questionText: "Janitor: \"I was sweeping the floor when Detective Emma suddenly ________ (open) the door!\"",
        correctAnswer: "opened",
        explanation: "Rule (Simple Past): Opening the door is a quick, completed action that interrupted the janitor's sweeping.",
        hint: "The sweeping was already happening. What sudden action did Detective Emma do to stop it?",
        interrogation: "You scared the life out of me! I'm just doing my late-night cleaning routine!",
        storyContinuation: "The janitor looks startled. Emma notices brown smudge marks all over his work boots!"
      },
      {
        id: 9,
        type: 'multiple-choice',
        storyContext: "Emma inspects the janitor's boots closely. He quickly tries to blame the school pet.",
        questionText: "Janitor: \"While I was cleaning the utility shelf, Whiskers the cat suddenly ________ a plate of fudge!\"",
        options: ["knocked over", "was knocking over", "knocks over"],
        correctAnswer: "knocked over",
        explanation: "Rule (Simple Past): Knocking something over is an instantaneous event that disrupts the ongoing cleaning activity.",
        hint: "Look for the sudden interruption caused by the cat while the janitor worked.",
        interrogation: "It wasn't me! The cat has a massive sweet tooth, I tell you!",
        storyContinuation: "Whiskers the cat is sitting on top of the locker, looking incredibly guilty."
      },
      {
        id: 10,
        type: 'fill-in-the-blank',
        storyContext: "Emma examines Whiskers. His white whiskers are completely covered in sticky chocolate icing!",
        questionText: "Whiskers: \"Meow! (While Detective Emma ________ (stare) at me, I quickly licked the remaining frosting!)\"",
        correctAnswer: "was staring",
        explanation: "Rule (Past Continuous): The detective's action of staring was an ongoing background process while the cat licked its paws.",
        hint: "What continuous action was Emma doing while the cat licked the frosting?",
        interrogation: "Meow... (Translation: Okay, I only ate the spilled parts from the floor!)",
        storyContinuation: "Mystery solved! Mia's dropped tray caused the crash, the Janitor cleaned up the mess, Whiskers ate the scraps, but Alex used the distraction to hide the whole cake inside his heavy backpack!"
      }
    ];

    // --- MAIN APP COMPONENT ---
    function App() {
      const [gameState, setGameState] = useState('menu'); // menu, intro, playing, feedback, gameover
      const [difficulty, setDifficulty] = useState('easy');
      const [questions, setQuestions] = useState(PREDEFINED_QUESTIONS);
      const [currentQIdx, setCurrentQIdx] = useState(0);
      const [score, setScore] = useState(0);
      const [userAnswer, setUserAnswer] = useState('');
      const [isCorrect, setIsCorrect] = useState(false);
      
      const [showHint, setShowHint] = useState(false);
      const [interrogateMode, setInterrogateMode] = useState(false);
      const [showHowTo, setShowHowTo] = useState(false);
      const [interrogationResponse, setInterrogationResponse] = useState('');

      const [speaking, setSpeaking] = useState(false);
      const ttsRef = useRef(null);

      useEffect(() => {
        initParticles();
      }, []);

      useEffect(() => {
        if (ttsRef.current) {
          ttsRef.current.pause();
          setSpeaking(false);
        }
        setInterrogateMode(false);
        setInterrogationResponse('');
      }, [currentQIdx]);

      const handleAudioInit = () => {
        audio.init();
        audio.startBGM();
      };

      const speakWithBrowserTTS = (text) => {
        if (!('speechSynthesis' in window)) return;
        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'en-US';
        utterance.rate = 0.85;
        utterance.onstart = () => setSpeaking(true);
        utterance.onend = () => setSpeaking(false);
        utterance.onerror = () => setSpeaking(false);
        window.speechSynthesis.speak(utterance);
      };

      const speakClueText = () => {
        audio.playSFX('click');
        const q = questions[currentQIdx];
        const cleanText = `${q.storyContext}. ${q.questionText.replace(/________/g, "blank")}`;

        if (speaking) {
          window.speechSynthesis.cancel();
          setSpeaking(false);
          return;
        }
        speakWithBrowserTTS(cleanText);
      };

      const handleInterrogate = () => {
        audio.playSFX('click');
        const q = questions[currentQIdx];
        setInterrogationResponse(q.interrogation);
      };

      // --- GAMEPLAY FLOW ---
      const startGame = () => {
        handleAudioInit();
        audio.playSFX('transition');
        setGameState('intro');
      };

      const beginGameplay = () => {
        audio.playSFX('click');
        setGameState('playing');
        setCurrentQIdx(0);
        setScore(0);
        resetTurnState();
      };

      const resetTurnState = () => {
        setUserAnswer('');
        setShowHint(false);
        setInterrogateMode(false);
      };

      const submitAnswer = (ans) => {
        const q = questions[currentQIdx];
        let correct = false;
        if (q.type === 'multiple-choice') {
          correct = (ans === q.correctAnswer);
          setUserAnswer(ans);
        } else {
          correct = (ans.toLowerCase().trim() === q.correctAnswer.toLowerCase().trim());
        }

        setIsCorrect(correct);
        if (correct) {
          setScore(s => s + 1);
          audio.playSFX('correct');
        } else {
          audio.playSFX('wrong');
        }
        setGameState('feedback');
      };

      const nextQuestion = () => {
        audio.playSFX('click');
        resetTurnState();
        if (currentQIdx < questions.length - 1) {
          setCurrentQIdx(i => i + 1);
          setGameState('playing');
        } else {
          audio.playSFX('transition');
          setGameState('gameover');
        }
      };

      const q = questions[currentQIdx];

      // --- RENDERS ---
      if (gameState === 'menu') {
        return (
          <div className="scene-enter flex flex-col items-center justify-center w-full space-y-8 text-center">
            {showHowTo && (
              <div className="fixed inset-0 bg-black/80 z-50 flex items-center justify-center p-4">
                <div className="bg-slate-900 border border-slate-700 p-8 rounded-xl max-w-md w-full">
                  <h3 className="text-2xl font-detective text-amber-400 mb-4">Investigation Rules</h3>
                  <ul className="text-left space-y-3 text-sm text-slate-300 mb-6 font-dossier list-disc pl-5">
                    <li>Read the detective's story log carefully.</li>
                    <li>Fill in the blanks using the correct tense balance.</li>
                    <li><strong className="text-indigo-400">Past Continuous</strong> (was/were + V-ing) is used for long background actions.</li>
                    <li><strong className="text-amber-500">Simple Past</strong> (V2 / -ed) is used for quick, sudden actions that interrupt.</li>
                  </ul>
                  <button onClick={() => {audio.playSFX('click'); setShowHowTo(false)}} className="w-full bg-slate-800 hover:bg-slate-700 py-3 rounded-lg font-bold reconstruction-btn">Close Folder</button>
                </div>
              </div>
            )}

            <div className="relative">
              <div className="absolute -inset-4 bg-amber-500/20 blur-2xl rounded-full"></div>
              <Icon name="search" size={64} className="text-amber-400 relative z-10 mx-auto mb-4 animate-pulse" />
            </div>
            
            <div>
              <h1 className="text-4xl md:text-6xl font-detective font-bold neon-text mb-3 uppercase tracking-widest">Midnight Cake<br/>Mystery</h1>
              <p className="font-dossier text-slate-400 tracking-widest">A Cinematic Grammar Investigation</p>
            </div>

            <div className="bg-slate-900/60 border border-slate-800 p-6 rounded-2xl w-full max-w-sm backdrop-blur-sm space-y-4 shadow-2xl relative z-20">
              
              <div className="flex justify-between items-center bg-slate-950 p-2 rounded-lg border border-slate-800">
                <span className="text-xs font-bold text-slate-400 uppercase ml-2">Mode</span>
                <select 
                  className="bg-slate-800 text-amber-400 text-sm font-bold p-2 rounded outline-none border-none cursor-pointer"
                  value={difficulty} onChange={(e) => {audio.playSFX('click'); setDifficulty(e.target.value);}}
                >
                  <option value="easy">Rookie (Hints ON)</option>
                  <option value="hard">Veteran (Hints OFF)</option>
                </select>
              </div>

              <button onClick={startGame} className="w-full bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold py-4 rounded-xl transition-all transform hover:scale-[1.02] shadow-[0_0_15px_rgba(251,191,36,0.3)] flex justify-center items-center gap-2 text-lg">
                <Icon name="play" /> Start Investigation
              </button>
              
              <button onClick={() => {audio.playSFX('click'); setShowHowTo(true)}} className="w-full bg-slate-800 hover:bg-slate-700 text-slate-300 py-3 rounded-xl text-sm font-bold flex items-center justify-center gap-2">
                <Icon name="book" size={18} /> View Grammar Guide
              </button>
            </div>
          </div>
        );
      }

      if (gameState === 'intro') {
        return (
          <div className="scene-enter w-full text-center space-y-8 z-20 relative">
            <AnimatedDetective state="start" speaking={speaking} />
            <div className="bg-slate-900/80 border border-slate-700 p-8 rounded-2xl shadow-xl backdrop-blur-sm mx-auto max-w-2xl text-left">
              <h2 className="text-amber-400 font-detective text-xl mb-4 text-center">Case Briefing</h2>
              <div className="text-slate-300 font-dossier leading-relaxed text-sm md:text-base">
                <Typewriter 
                  text="Welcome back, Detective! Emma here. The school's giant celebration cake was stolen right out of the lounge.\n\nTo break their alibis, you must carefully distinguish between the ongoing background activity (Past Continuous) and the sudden event that cut through it (Simple Past). The database has been recalibrated for a perfect balance of both forms.\n\nLet's review the suspect logs!"
                  speed={20}
                />
              </div>
            </div>
            <button onClick={beginGameplay} className="bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold py-3 px-8 rounded-full transition-all hover:scale-105 shadow-[0_0_15px_rgba(251,191,36,0.4)]">
              Examine First Clue
            </button>
          </div>
        );
      }

      // GAME UI HEADER
      const GameHeader = () => (
        <div className="flex justify-between items-center mb-6 pb-4 border-b border-slate-800">
          <div className="flex items-center gap-3">
            <Icon name="search" size={20} className="text-amber-500" />
            <span className="font-detective tracking-wider text-amber-500 text-lg">DOSSIER SOAL {currentQIdx + 1}/10</span>
          </div>
          <div className="flex gap-2">
            <button onClick={() => {audio.playSFX('click'); audio.toggleBGM();}} className="p-2 bg-slate-800 rounded text-slate-400 hover:text-amber-400">
              {audio.bgmEnabled ? <Icon name="musicOn" size={16}/> : <Icon name="musicOff" size={16}/>}
            </button>
            <button onClick={() => {audio.playSFX('click'); audio.toggleSFX();}} className="p-2 bg-slate-800 rounded text-slate-400 hover:text-amber-400">
              {audio.sfxEnabled ? <Icon name="soundOn" size={16}/> : <Icon name="soundOff" size={16}/>}
            </button>
          </div>
        </div>
      );

      if (gameState === 'playing') {
        return (
          <div className="scene-enter w-full max-w-2xl bg-slate-900/90 border border-slate-700 p-6 sm:p-8 rounded-2xl shadow-2xl backdrop-blur-md z-20 relative">
            <GameHeader />
            
            <AnimatedDetective state={interrogateMode ? "interrogate" : "playing"} speaking={speaking} />

            <div className="mt-4 bg-slate-950/80 border-l-4 border-amber-500 p-4 rounded-r-lg mb-6 shadow-inner flex justify-between items-start gap-3 text-left">
              <Typewriter text={q.storyContext} speed={15} />
              <button onClick={speakClueText} className={`p-2 rounded-lg flex-shrink-0 transition-all ${speaking ? 'bg-amber-500 text-slate-900 animate-pulse' : 'bg-slate-800 text-slate-400 hover:text-amber-400'}`}>
                {speaking ? <Icon name="volumeX" size={16}/> : <Icon name="volume2" size={16}/>}
              </button>
            </div>

            {/* Interrogation Box */}
            {interrogateMode && (
              <div className="mb-6 bg-indigo-950/40 p-5 rounded-xl border border-indigo-500/30 shadow-inner relative animate-fadeInScale text-left">
                <div className="absolute top-3 right-3 text-indigo-400 opacity-50"><Icon name="message" size={40} /></div>
                <h4 className="text-indigo-400 font-bold font-detective mb-3 flex items-center gap-2"><Icon name="search" size={18} /> IN-DEPTH INTERROGATION</h4>
                <div className="flex flex-col gap-3 z-10 relative">
                  <p className="text-xs text-indigo-300 font-dossier">Demand the suspect repeat their exact defensive timeline statement.</p>
                  <div className="flex gap-3 justify-end">
                    <button onClick={() => {audio.playSFX('click'); setInterrogateMode(false)}} className="px-4 py-2 text-xs font-bold text-slate-400 hover:text-white">Back</button>
                    <button onClick={handleInterrogate} className="bg-indigo-600 hover:bg-indigo-500 text-white font-bold py-2 px-5 rounded-lg text-xs flex items-center gap-2">
                      Cross-Examine Suspect
                    </button>
                  </div>
                  {interrogationResponse && (
                    <div className="mt-2 bg-slate-950 p-4 rounded-lg border-l-4 border-l-indigo-500 text-slate-300 text-sm font-dossier italic">
                      "{interrogationResponse}"
                    </div>
                  )}
                </div>
              </div>
            )}

            <div className="bg-slate-800/50 border border-slate-700 p-6 rounded-xl relative text-left">
              <p className="text-lg font-mono text-slate-100 mb-6 leading-relaxed border-b border-slate-700 pb-4">{q.questionText}</p>

              {/* Action Buttons */}
              <div className="absolute -top-3 right-4 flex gap-2">
                {!interrogateMode && (
                  <button onClick={() => {audio.playSFX('click'); setInterrogateMode(true)}} className="px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase transition-colors flex items-center gap-1 bg-slate-950 text-indigo-400 border border-indigo-900">
                    <Icon name="message" size={12}/> Interrogate
                  </button>
                )}
                {difficulty === 'easy' && (
                  <button onClick={() => {audio.playSFX('click'); setShowHint(true);}} className={`px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase transition-colors flex items-center gap-1 ${showHint ? 'bg-amber-500 text-slate-900' : 'bg-slate-950 text-amber-400 border border-amber-900'}`}>
                    <Icon name="lightbulb" size={12}/> Clue Hint
                  </button>
                )}
              </div>

              {showHint && (
                <div className="mb-6 bg-amber-950/30 border border-amber-500/30 p-4 rounded-lg text-sm text-amber-200 animate-fadeInScale">
                  <strong className="text-amber-500 font-bold block mb-1">Grammar Hint:</strong> {q.hint}
                </div>
              )}

              {/* Input Engine */}
              {q.type === 'multiple-choice' ? (
                <div className="space-y-3">
                  {q.options.map((opt, i) => (
                    <button key={i} onClick={() => submitAnswer(opt)} className="w-full text-left bg-slate-900 hover:bg-amber-500 hover:text-slate-950 border border-slate-700 hover:border-amber-500 p-4 rounded-xl transition-all font-mono font-bold group text-slate-200">
                      {opt}
                    </button>
                  ))}
                </div>
              ) : (
                <div className="flex gap-2">
                  <input type="text" value={userAnswer} onChange={e=>setUserAnswer(e.target.value)} onKeyDown={e=>{if(e.key==='Enter'&&userAnswer)submitAnswer(userAnswer);}} placeholder="Type past verb form..." className="flex-1 bg-slate-950 border border-slate-600 focus:border-amber-500 rounded-lg p-3 text-white font-mono outline-none" autoFocus/>
                  <button onClick={() => submitAnswer(userAnswer)} disabled={!userAnswer.trim()} className="bg-amber-500 hover:bg-amber-400 disabled:bg-slate-800 text-slate-950 font-bold px-6 rounded-lg transition-all">Verify</button>
                </div>
              )}
            </div>
          </div>
        );
      }

      if (gameState === 'feedback') {
        return (
          <div className="scene-enter w-full max-w-2xl bg-slate-900/90 border border-slate-700 p-6 sm:p-8 rounded-2xl shadow-2xl backdrop-blur-md z-20 relative">
            <GameHeader />
            <AnimatedDetective state={isCorrect ? 'correct' : 'wrong'} />
            
            <div className={`mt-6 p-6 rounded-xl border text-left ${isCorrect ? 'bg-emerald-950/40 border-emerald-500/40' : 'bg-rose-950/40 border-rose-500/40'}`}>
              <div className="flex items-start gap-4">
                {isCorrect ? <Icon name="shieldCheck" size={32} className="text-emerald-400"/> : <Icon name="shieldX" size={32} className="text-rose-400"/>}
                <div className="flex-1">
                  <h3 className={`text-xl font-detective font-bold mb-2 ${isCorrect ? 'text-emerald-400' : 'text-rose-400'}`}>
                    {isCorrect ? "CORRECT LOGIC!" : "DEDUCTION ERROR!"}
                  </h3>
                  {!isCorrect && (
                     <p className="text-slate-300 text-sm mb-3">The verified timeline answer was: <span className="font-mono bg-slate-950 px-2 py-1 rounded text-amber-400 font-bold">{q.correctAnswer}</span></p>
                  )}
                  <p className="text-sm text-slate-300 bg-slate-950/50 p-3 rounded border border-slate-800 font-dossier">
                    {q.explanation}
                  </p>
                </div>
              </div>
            </div>

            <div className="mt-4 p-4 text-sm text-slate-400 italic text-center font-dossier">
               "{q.storyContinuation}"
            </div>

            <button onClick={nextQuestion} className="w-full mt-6 bg-slate-800 hover:bg-amber-500 hover:text-slate-950 text-amber-400 font-bold py-4 rounded-xl transition-all border border-slate-700 hover:border-amber-500 flex items-center justify-center gap-2">
              {currentQIdx < questions.length - 1 ? 'Next Case File' : 'View Final Verdict'} <Icon name="arrowRight" size={18}/>
            </button>
          </div>
        );
      }

      if (gameState === 'gameover') {
        return (
          <div className="scene-enter w-full text-center space-y-6 max-w-xl mx-auto z-20 relative">
            <AnimatedDetective state="gameover" />
            <h2 className="text-4xl font-detective font-bold text-amber-400 neon-text">CASE INVESTIGATION CLOSED</h2>
            
            <div className="bg-slate-900/80 border border-slate-700 p-8 rounded-2xl shadow-xl backdrop-blur-sm">
              <div className="text-6xl font-black font-mono text-white mb-2">{score}<span className="text-2xl text-slate-500">/10</span></div>
              <p className="text-slate-400 text-sm tracking-widest uppercase font-bold mb-6">Deduction Accuracy Score</p>
              
              <div className="text-left bg-slate-950 p-4 rounded-lg border border-slate-800 font-dossier text-sm text-slate-300 mb-6">
                 <strong className="text-amber-500 font-detective text-base block mb-2 text-center">Official Lab Summary</strong>
                 Great job! By perfectly balancing both ongoing background actions (<span className="text-indigo-400 font-bold">Past Continuous</span>) and sudden interrupting occurrences (<span className="text-amber-400 font-bold">Simple Past</span>), you successfully parsed the chaotic timeline of the theft event. The suspect has been filed and reported.
              </div>

              <button onClick={() => {audio.playSFX('click'); setGameState('menu')}} className="w-full bg-amber-500 hover:bg-amber-400 text-slate-950 font-bold py-4 rounded-xl transition-all shadow-[0_0_15px_rgba(251,191,36,0.3)]">
                Return to Main Office
              </button>
            </div>
          </div>
        );
      }

      return null;
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
